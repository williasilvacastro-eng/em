<Window x:Class="emu2026.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VORTEX PRO - LOGIN" Height="350" Width="400"
        Background="#181818" Foreground="White"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <LinearGradientBrush x:Key="AccentColor" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFC107" Offset="0.0"/>
            <GradientStop Color="#FF555555" Offset="1.0"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Border BorderBrush="#333" BorderThickness="1" Background="#121212" CornerRadius="8">
        <Grid Margin="20">
            <StackPanel x:Name="LoginPanel" VerticalAlignment="Center">

                <TextBlock Text="VORTEX PRO" FontWeight="Bold" FontSize="24" Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Restricted Access - License Required" Foreground="#888" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="New Features Coming Soon" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="Stay tuned for future premium updates and new modules." Foreground="#AFAFAF" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="txtDependencyStatus" Text="Checking drivers before login..." Foreground="#AAA" FontSize="11" TextAlignment="Center" Margin="10,0,10,20" TextWrapping="Wrap"/>

                <TextBlock Text="Enter your License Key:" FontSize="11" Foreground="#AAA" Margin="0,0,0,5"/>
                <TextBox x:Name="txtKey" Height="30" Background="#333" Foreground="White" BorderThickness="1" BorderBrush="#555" Padding="5" Margin="0,0,0,25" HorizontalContentAlignment="Center"/>

                <Button x:Name="btnLogin" Content="VERIFY LICENSE &amp; LOGIN" Height="40" Background="{DynamicResource AccentColor}" Foreground="Black" FontWeight="Bold" Cursor="Hand" Click="BtnLogin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="UPDATE LOG" Height="34" Background="#242424" Foreground="White" FontWeight="Bold" BorderBrush="#3A3A3A" BorderThickness="1" Cursor="Hand" Margin="0,12,0,0" Click="BtnUpdateLog_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Exit" Background="Transparent" Foreground="#888" BorderThickness="0" Margin="0,15,0,0" Cursor="Hand" Click="BtnExit_Click"/>
            </StackPanel>

            <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" Visibility="Collapsed">
                <TextBlock Text="VORTEX PRO" FontWeight="Bold" FontSize="24" Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="txtLoadingStatus" Text="Preparing emulator dependencies..." Foreground="#888" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
