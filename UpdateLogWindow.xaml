<Window x:Class="emu2026.UpdateLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VORTEX PRO - Update Log"
        Height="560"
        Width="760"
        Background="#151515"
        Foreground="White"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <LinearGradientBrush x:Key="AccentColor" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFC107" Offset="0.0"/>
            <GradientStop Color="#FF555555" Offset="1.0"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardColor" Color="#202020"/>
    </Window.Resources>

    <Border BorderBrush="#333" BorderThickness="1" Background="#121212">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,18">
                <TextBlock Text="UPDATE LOG" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="26"/>
                <TextBlock Text="Latest improvements, performance upgrades and what is coming next." Foreground="#B8B8B8" FontSize="13" Margin="0,6,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource CardColor}" BorderBrush="#333" BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Version 2026.1" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="Current release" Foreground="#888" Margin="0,3,0,12"/>
                            <TextBlock Text="Reduced input delay for a more responsive and stable emulator experience." TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="Improved controller response and overall movement smoothness during gameplay." TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="Automatic dependency setup to make installation faster and easier for new users." TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardColor}" BorderBrush="#333" BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Performance upgrades" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Text="Optimization pass" Foreground="#888" Margin="0,3,0,12"/>
                            <TextBlock Text="Cleaner startup flow for more consistent launches." TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="Better runtime stability with a more polished user experience." TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBlock Text="New Features Coming Soon." TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#171717" BorderBrush="#2E2E2E" BorderThickness="1" CornerRadius="10" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Support reminder" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="If installation fails or the emulator does not open correctly, open a support ticket in the Discord server for direct help." Foreground="#B8B8B8" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="CLOSE"
                        Width="120"
                        Height="38"
                        Background="{DynamicResource AccentColor}"
                        Foreground="Black"
                        FontWeight="Bold"
                        Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
